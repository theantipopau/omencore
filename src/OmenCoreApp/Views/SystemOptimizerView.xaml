<UserControl x:Class="OmenCore.Views.SystemOptimizerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="Transparent">

    <UserControl.Resources>
        <!-- Optimization Item Template -->
        <DataTemplate x:Key="OptimizationItemTemplate">
            <Border Style="{StaticResource Omen.Card.Optimizer}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <TextBlock Text="{Binding Name}" 
                                       FontSize="14" 
                                       FontWeight="SemiBold"
                                       Foreground="White"/>
                            <Border CornerRadius="4" 
                                    Padding="6,2" 
                                    Margin="8,0,0,0"
                                    VerticalAlignment="Center">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#1A00C8C8"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Risk}" Value="Medium">
                                                <Setter Property="Background" Value="#1AFFB800"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Risk}" Value="High">
                                                <Setter Property="Background" Value="#1AFF005C"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding RiskText}" FontSize="10">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#00C8C8"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Risk}" Value="Medium">
                                                    <Setter Property="Foreground" Value="#FFB800"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Risk}" Value="High">
                                                    <Setter Property="Foreground" Value="#FF005C"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="{Binding Description}" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   MaxWidth="500"/>
                        
                        <TextBlock Text="{Binding Warning}" 
                                   FontSize="11" 
                                   Foreground="{StaticResource WarningBrush}"
                                   Margin="0,4,0,0"
                                   Visibility="{Binding HasWarning, Converter={StaticResource BoolToVisibility}}"/>

                        <Expander Margin="0,10,0,0"
                                  IsExpanded="{Binding IsDetailsExpanded, Mode=TwoWay}"
                                  Visibility="{Binding HasDetails, Converter={StaticResource BoolToVisibility}}">
                            <Expander.Header>
                                <TextBlock Text="What changes" FontSize="11" Foreground="{StaticResource AccentBlueBrush}"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="{Binding DetailedDescription}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           TextWrapping="Wrap"
                                           Visibility="{Binding HasDetailedDescription, Converter={StaticResource BoolToVisibility}}"/>

                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasRegistryPreview, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Registry keys" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    <ItemsControl ItemsSource="{Binding AffectedRegistryKeys}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasServicePreview, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Services or commands" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    <ItemsControl ItemsSource="{Binding ServiceNamesAffected}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>

                                <StackPanel Margin="0,8,0,0"
                                            Visibility="{Binding HasUndoInstructions, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="Manual undo" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    <TextBlock Text="{Binding UndoInstructions}" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap" Margin="0,2,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <ToggleButton Style="{StaticResource Omen.Toggle.Switch.Wide}"
                                      IsChecked="{Binding IsEnabled, Mode=OneWay}"
                                      IsEnabled="{Binding IsApplying, Converter={StaticResource InverseBooleanConverter}}"
                                      Click="OnToggleClicked"
                                      HorizontalAlignment="Center"
                                      Tag="{Binding}"/>
                        <TextBlock Text="Applying..."
                                   FontSize="11"
                                   Margin="0,6,0,0"
                                   HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding IsApplying, Converter={StaticResource BoolToVisibility}}"/>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <Grid>
        <!-- Loading Overlay -->
        <Border x:Name="LoadingOverlay" 
                Style="{StaticResource Omen.Busy.Overlay}"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}"
                Panel.ZIndex="100">
            <Border Style="{StaticResource Omen.Busy.Panel}" HorizontalAlignment="Center" VerticalAlignment="Center">
                <StackPanel>
                    <ProgressBar Style="{StaticResource Omen.Busy.Progress}"
                                 IsIndeterminate="True"
                                 Margin="0,0,0,10"
                                 Visibility="{Binding HasOperationProgress, Converter={StaticResource InverseBooleanConverter}}"/>
                    <ProgressBar Style="{StaticResource Omen.Busy.Progress}"
                                 Value="{Binding OperationProgressValue, Mode=OneWay}"
                                 Maximum="{Binding OperationProgressMaximum}"
                                 Margin="0,0,0,10"
                                 Visibility="{Binding HasOperationProgress, Converter={StaticResource BoolToVisibility}}"/>
                    <TextBlock Text="{Binding StatusMessage}" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               TextWrapping="Wrap"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding OperationProgressText}"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               FontSize="11"
                               Margin="0,6,0,0"
                               HorizontalAlignment="Center"
                               Visibility="{Binding HasOperationProgress, Converter={StaticResource BoolToVisibility}}"/>
                </StackPanel>
            </Border>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="24">
                <!-- Header -->
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path Data="{StaticResource IconSettings}" Width="20" Height="20" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <StackPanel>
                                <TextBlock Text="System Optimizer" Style="{StaticResource Headline}"/>
                                <TextBlock Text="Fine-tune Windows for gaming performance" Style="{StaticResource Caption}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding RefreshCommand}" Padding="12,6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <Path Data="{StaticResource IconRefresh}" Width="12" Height="12" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform" Margin="0,0,6,0"/>
                                <TextBlock Text="Refresh" FontSize="12"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- Summary & Presets -->
                <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="12" Padding="20" Margin="0,0,0,24">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="{Binding OptimizationSummary}" 
                                       FontSize="18" 
                                       FontWeight="SemiBold" 
                                       Foreground="White"/>
                            <TextBlock Text="{Binding StatusMessage}" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding LastVerifiedText}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       Margin="0,6,0,0"/>
                            <Border Style="{StaticResource Omen.Toast}" Margin="0,8,0,0" HorizontalAlignment="Left">
                                <TextBlock Text="{Binding VerificationSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                            </Border>
                            <Border Background="#4A3A00"
                                    CornerRadius="8"
                                    Padding="10,6"
                                    Margin="0,8,0,0"
                                    HorizontalAlignment="Left"
                                    Visibility="{Binding HasStateDrift, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="External changes were detected during verification. Review the affected toggles below."
                                           FontSize="11"
                                           Foreground="#FFD166"
                                           TextWrapping="Wrap"/>
                            </Border>
                            <StackPanel Margin="0,10,0,0"
                                        Visibility="{Binding HasOperationProgress, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Text="{Binding OperationProgressLabel}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}"/>
                                <ProgressBar Style="{StaticResource Omen.Busy.Progress}"
                                             Value="{Binding OperationProgressValue, Mode=OneWay}"
                                             Maximum="{Binding OperationProgressMaximum}"
                                             Margin="0,6,0,0"/>
                                <TextBlock Text="{Binding OperationProgressText}"
                                           FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                <Button Style="{StaticResource Omen.Button.Toolbar.Accent}"
                                    Command="{Binding ApplyGamingMaxCommand}"
                                    Margin="0,0,8,0"
                                    ToolTip="Apply all optimizations for maximum gaming performance">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconGamepad}" Width="14" Height="14" Fill="#0F111C" Stretch="Uniform" Margin="0,0,6,0"/>
                                    <TextBlock Text="Gaming Max" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                                <Button Style="{StaticResource Omen.Button.Toolbar}"
                                    Command="{Binding ApplyBalancedCommand}"
                                    Margin="0,0,8,0"
                                    ToolTip="Apply recommended optimizations only">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconPerformance}" Width="14" Height="14" Fill="White" Stretch="Uniform" Margin="0,0,6,0"/>
                                    <TextBlock Text="Balanced" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                                <Button Style="{StaticResource Omen.Button.Toolbar.Danger}"
                                    Command="{Binding RevertAllCommand}"
                                    ToolTip="Restore all settings to Windows defaults">
                                <StackPanel Orientation="Horizontal">
                                    <Path Data="{StaticResource IconRestore}" Width="14" Height="14" Fill="White" Stretch="Uniform" Margin="0,0,6,0"/>
                                    <TextBlock Text="Revert All" FontSize="13" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Two Column Layout -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left Column -->
                    <StackPanel Grid.Column="0">
                        <!-- Power Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconPerformance}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Power &amp; Performance" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyPowerCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding PowerOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>

                        <!-- Service Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconSettings}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Windows Services" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyServicesCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding ServiceOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>

                        <!-- Network Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconNetwork}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Network &amp; Latency" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyNetworkCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding NetworkOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>
                    </StackPanel>

                    <!-- Right Column -->
                    <StackPanel Grid.Column="2">
                        <!-- Input Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconMouse}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Input &amp; Gaming" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyInputCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding InputOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>

                        <!-- Visual Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconEye}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Visual Effects" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyVisualCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding VisualOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>

                        <!-- Storage Optimizations -->
                        <Grid Margin="0,16,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" Grid.Column="0">
                                <Path Data="{StaticResource IconStorage}" Width="14" Height="14" Fill="{StaticResource AccentBlueBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <TextBlock Text="Storage &amp; Disk" Style="{StaticResource Omen.Text.Section.Utility}" Margin="0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Command="{Binding ApplyStorageCommand}" Padding="8,4">
                                <TextBlock Text="Apply All" FontSize="10"/>
                            </Button>
                        </Grid>
                        <ItemsControl ItemsSource="{Binding StorageOptimizations}" 
                                      ItemTemplate="{StaticResource OptimizationItemTemplate}"/>
                    </StackPanel>
                </Grid>

                <!-- Footer Info -->
                <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="8" Padding="16" Margin="0,24,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Path Data="{StaticResource IconAbout}" Width="14" Height="14" Fill="{StaticResource WarningBrush}" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Important Notes" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap">
                            • A system restore point is created before applying presets&#x0a;
                            • Some changes may require a restart to take effect&#x0a;
                            • Medium/High risk optimizations may affect system stability or features&#x0a;
                            • Use "Revert All" to restore original settings at any time
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
