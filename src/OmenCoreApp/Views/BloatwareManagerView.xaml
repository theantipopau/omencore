<UserControl x:Class="OmenCore.Views.BloatwareManagerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:OmenCore.ViewModels"
             xmlns:bloat="clr-namespace:OmenCore.Services.BloatwareManager"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1000"
             Background="Transparent">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Style="{StaticResource CardBorder}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="{StaticResource IconTrash}" Width="20" Height="20" Fill="{StaticResource AccentBrush}" Stretch="Uniform" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Bloatware Manager" Style="{StaticResource Headline}" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="Remove pre-installed bloatware to improve system performance and reduce clutter. Low-risk items are safe to remove." 
                               Style="{StaticResource Caption}" 
                               TextWrapping="Wrap"
                               MaxWidth="600"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Stats Panel -->
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Border Style="{StaticResource Omen.Card.Utility}" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding TotalCount}" Style="{StaticResource UtilityMetricValue}"/>
                            <TextBlock Text="Detected" Style="{StaticResource UtilityMetricLabel}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Omen.Card.Utility}" Padding="12,8" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="{Binding RemovedCount}" Style="{StaticResource UtilityMetricValue}" Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Removed" Style="{StaticResource UtilityMetricLabel}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource Omen.Card.Utility}" Padding="12,8">
                        <StackPanel>
                            <TextBlock Text="{Binding LowRiskCount}" Style="{StaticResource UtilityMetricValue}" Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Low Risk" Style="{StaticResource UtilityMetricLabel}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Toolbar -->
        <Border Grid.Row="1" Style="{StaticResource CardBorder}" Margin="0,0,0,4" Padding="12,10">
            <StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Action Buttons -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Button Command="{Binding ScanCommand}" 
                            Style="{StaticResource PrimaryButton}" 
                            Margin="0,0,8,0"
                            Padding="12,6"
                            AutomationProperties.Name="Scan for Bloatware">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRefresh}" Width="14" Height="14" Fill="White" Stretch="Uniform" Margin="0,0,6,0"/>
                            <TextBlock Text="Scan" FontSize="12"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RemoveAllLowRiskCommand}" 
                            Style="{StaticResource ModernButton}" 
                            Background="#2E7D32"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            AutomationProperties.Name="Remove All Low-Risk Items">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconTrash}" Width="12" Height="12" Fill="White" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Remove Low-Risk" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding CancelBulkOperationCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,6"
                            Visibility="{Binding CanCancelBulkOperation, Converter={StaticResource BoolToVisibility}}"
                            AutomationProperties.Name="Cancel Bulk Operation">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconClose}" Width="12" Height="12" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Cancel" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Filter/Search -->
                <StackPanel Grid.Column="1" Margin="8,0">
                    <!-- Text search + category row -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <Grid MinWidth="160" MaxWidth="260" Margin="0,0,8,0">
                            <TextBox Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource ModernTextBox}"
                                     Padding="8,5"/>
                            <TextBlock Text="Search apps, publishers..."
                                       IsHitTestVisible="False"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="11">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FilterText}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <ComboBox ItemsSource="{Binding Categories}"
                                  SelectedItem="{Binding SelectedCategory}"
                                  Style="{StaticResource ModernComboBox}"
                                  Width="120">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>
                    <!-- Risk Level Filter -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Risk:" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextTertiaryBrush}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <RadioButton Content="All"    IsChecked="{Binding IsRiskAll,    Mode=TwoWay}" GroupName="RiskFilter" Style="{StaticResource TimeRangeButton}" Margin="0,0,4,0"/>
                        <RadioButton IsChecked="{Binding IsRiskLow,    Mode=TwoWay}" GroupName="RiskFilter" Style="{StaticResource TimeRangeButton}" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource SuccessBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Low"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsRiskMedium, Mode=TwoWay}" GroupName="RiskFilter" Style="{StaticResource TimeRangeButton}" Margin="0,0,4,0">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource WarningBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="Med"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton IsChecked="{Binding IsRiskHigh,   Mode=TwoWay}" GroupName="RiskFilter" Style="{StaticResource TimeRangeButton}">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                <TextBlock Text="High"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

                <!-- Selected Item Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Command="{Binding RemoveSelectedCommand}" 
                            Style="{StaticResource ModernButton}"
                            Background="#C62828"
                            Margin="0,0,8,0"
                            Padding="10,6"
                            AutomationProperties.Name="Remove Selected Item">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconTrash}" Width="12" Height="12" Fill="White" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Remove" FontSize="11"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding RestoreSelectedCommand}" 
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,6"
                            AutomationProperties.Name="Restore Selected Item">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconRestore}" Width="12" Height="12" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Restore" FontSize="11"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
            <!-- Bulk Remove Progress -->
            <Grid Margin="0,8,0,0"
                  Visibility="{Binding IsBulkRemoving, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Value="{Binding BulkRemoveProgress}" Maximum="{Binding BulkRemoveTotal}"
                             Height="4"
                             Background="{StaticResource SurfaceMediumBrush}"
                             Foreground="{StaticResource SuccessBrush}"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding BulkRemoveProgressText}"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>

            <Grid Margin="0,8,0,0"
                  Visibility="{Binding IsBulkRestoring, Converter={StaticResource BoolToVisibility}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <ProgressBar Grid.Column="0" Value="{Binding BulkRestoreProgress}" Maximum="{Binding BulkRestoreTotal}"
                             Height="4"
                             Background="{StaticResource SurfaceMediumBrush}"
                             Foreground="{StaticResource AccentBrush}"
                             BorderThickness="0"/>
                <TextBlock Grid.Column="1"
                           Text="{Binding BulkRestoreProgressText}"
                           FontSize="10"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center"
                           Margin="8,0,0,0"/>
            </Grid>

            <Border Style="{StaticResource Omen.Toast}" Margin="0,8,0,0" HorizontalAlignment="Left">
                <TextBlock Text="{Binding StatusMessage}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
            </Border>

            <Border Style="{StaticResource CardBorder}"
                    Margin="0,10,0,0"
                    Visibility="{Binding IsRemovalPreviewVisible, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Path Data="{StaticResource IconWarning}" Width="14" Height="14" Fill="{StaticResource WarningBrush}" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding RemovalPreviewTitle}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                    </StackPanel>

                    <TextBlock Text="{Binding RemovalPreviewSummary}" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <TextBlock Text="{Binding RemovalPreviewEstimatedText}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" Margin="0,2,0,8"/>

                    <ListView ItemsSource="{Binding RemovalPreviewItems}" Height="160" Margin="0,0,0,10"
                              Background="{StaticResource SurfaceDarkBrush}" BorderBrush="{StaticResource BorderBrush}">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Remove" Width="60">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="App" Width="220" DisplayMemberBinding="{Binding Name}"/>
                                <GridViewColumn Header="Risk" Width="70" DisplayMemberBinding="{Binding Risk}"/>
                                <GridViewColumn Header="Est." Width="60" DisplayMemberBinding="{Binding EstimatedText}"/>
                                <GridViewColumn Header="Dependency Hint" Width="280" DisplayMemberBinding="{Binding DependencyHint}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Command="{Binding ToggleAllPreviewItemsCommand}" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,8,0">
                            <TextBlock Text="Toggle All" FontSize="11"/>
                        </Button>
                        <Button Command="{Binding CancelRemovalPreviewCommand}" Style="{StaticResource SecondaryButton}" Padding="10,6" Margin="0,0,8,0">
                            <TextBlock Text="Cancel" FontSize="11"/>
                        </Button>
                        <Button Command="{Binding ConfirmRemovalPreviewCommand}" Style="{StaticResource ModernButton}" Background="#C62828" Padding="10,6">
                            <TextBlock Text="Remove Selected" FontSize="11" Foreground="White"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
            </StackPanel>
        </Border>

        <!-- App List -->
        <Border Grid.Row="2" Style="{StaticResource CardBorder}">
            <Grid>
                <!-- Loading Overlay -->
                <Border Style="{StaticResource Omen.Busy.Overlay}"
                        CornerRadius="8" 
                        Visibility="{Binding IsScanning, Converter={StaticResource BoolToVisibility}}"
                        Panel.ZIndex="10">
                    <Border Style="{StaticResource Omen.Busy.Panel}" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel>
                            <ProgressBar Style="{StaticResource Omen.Busy.Progress}" IsIndeterminate="True" Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding StatusMessage}" 
                                       Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </Border>

                <!-- Empty State - only show when not scanning AND count is zero -->
                <StackPanel VerticalAlignment="Center" 
                            HorizontalAlignment="Center">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <MultiDataTrigger>
                                    <MultiDataTrigger.Conditions>
                                        <Condition Binding="{Binding TotalCount}" Value="0"/>
                                        <Condition Binding="{Binding IsScanning}" Value="False"/>
                                    </MultiDataTrigger.Conditions>
                                    <Setter Property="Visibility" Value="Visible"/>
                                </MultiDataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Path Data="{StaticResource IconSearch}" Width="48" Height="48" Fill="{StaticResource TextTertiaryBrush}" Stretch="Uniform" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                    <TextBlock Text="No bloatware detected" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Click 'Scan' to search for bloatware" FontSize="12" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- App ListView -->
                <ListView ItemsSource="{Binding FilteredApps}" 
                          SelectedItem="{Binding SelectedApp}"
                          Style="{StaticResource ModernListView}"
                          ScrollViewer.IsDeferredScrollingEnabled="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Status" Width="70">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                                    <Setter Property="Background" Value="{StaticResource SurfaceLightBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource SurfaceMediumBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LastRemovalStatus}" Value="Failed">
                                                            <Setter Property="Background" Value="#4A0000"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding LastRemovalStatus}" Value="Skipped">
                                                            <Setter Property="Background" Value="#4A3A00"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="9" FontWeight="Bold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="INSTALLED"/>
                                                        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsRemoved}" Value="True">
                                                                <Setter Property="Text" Value="REMOVED"/>
                                                                <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LastRemovalStatus}" Value="Failed">
                                                                <Setter Property="Text" Value="FAILED"/>
                                                                <Setter Property="Foreground" Value="#FF6B6B"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding LastRemovalStatus}" Value="Skipped">
                                                                <Setter Property="Text" Value="SKIPPED"/>
                                                                <Setter Property="Foreground" Value="#FFD166"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Name" Width="200">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Category" Width="120">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource StatusBadge}" Background="{StaticResource SurfaceMediumBrush}">
                                            <TextBlock Text="{Binding Category}" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Type" Width="100">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Type}" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Risk" Width="80">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border HorizontalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource StatusBadge}">
                                                    <Setter Property="Background" Value="{StaticResource SurfaceMediumBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RemovalRisk}" Value="Low">
                                                            <Setter Property="Background" Value="#1B5E20"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RemovalRisk}" Value="Medium">
                                                            <Setter Property="Background" Value="#E65100"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RemovalRisk}" Value="High">
                                                            <Setter Property="Background" Value="#B71C1C"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding RemovalRisk}" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                        </Border>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Description" Width="300">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Description}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextSecondaryBrush}" ToolTip="{Binding Description}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Publisher" Width="150">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Publisher}" TextTrimming="CharacterEllipsis" Foreground="{StaticResource TextTertiaryBrush}" ToolTip="{Binding Publisher}"/>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="{StaticResource SurfaceDarkBrush}" CornerRadius="0,0,8,8" Padding="12,8" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           Text="{Binding StatusMessage}" 
                           Foreground="{StaticResource TextSecondaryBrush}" 
                           FontSize="11"
                           VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Command="{Binding ExportResultLogCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4"
                            Margin="0,0,10,0"
                            ToolTip="Export removal results to a log file"
                            AutomationProperties.Name="Export Removal Log">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconExport}" Width="11" Height="11" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="Export Log" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Button Command="{Binding ViewLastReportCommand}"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,4"
                            Margin="0,0,10,0"
                            Visibility="{Binding HasLastReport, Converter={StaticResource BoolToVisibility}}"
                            ToolTip="Open the most recent removal report"
                            AutomationProperties.Name="View Last Removal Report">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{StaticResource IconExport}" Width="11" Height="11" Fill="{StaticResource TextSecondaryBrush}" Stretch="Uniform" Margin="0,0,4,0"/>
                            <TextBlock Text="View Report" FontSize="10"/>
                        </StackPanel>
                    </Button>
                    <Path Data="{StaticResource IconWarning}" Width="12" Height="12" Fill="{StaticResource WarningBrush}" Stretch="Uniform" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Some removals may require a restart" 
                               Foreground="{StaticResource TextTertiaryBrush}" 
                               FontSize="10"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
