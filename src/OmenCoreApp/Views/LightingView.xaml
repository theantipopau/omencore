<UserControl x:Class="OmenCore.Views.LightingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:OmenCore.Controls"
             xmlns:utils="clr-namespace:OmenCore.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="700" d:DesignWidth="1000">
    <UserControl.Resources>
        <!-- Device Card Style -->
        <Style x:Key="DeviceCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SurfaceDarkBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                    <Setter Property="Background" Value="#FF252830"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        
        <!-- Connection Status Indicator Style -->
        <Style x:Key="ConnectionIndicator" TargetType="Ellipse">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,6,0"/>
        </Style>
        
        <!-- Brand Section Header Style -->
        <Style x:Key="BrandSectionHeader" TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal"/>
            <Setter Property="Margin" Value="0,0,0,16"/>
        </Style>
    </UserControl.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with Connection Overview and Sync All -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0">
                <TextBlock Text="RGB Lighting &amp; Peripherals" 
                           FontSize="28" FontWeight="Bold" 
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                    <!-- Connection Status Badges — shown for all enabled providers with status-aware color -->
                    <Border Background="#0D000000" BorderBrush="{Binding CorsairStatusBrush}" BorderThickness="1" 
                            CornerRadius="10" Padding="10,4" Margin="0,0,8,0"
                            ToolTip="{Binding CorsairStatusDetail}"
                            Visibility="{Binding IsCorsairEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Fill="{Binding CorsairStatusBrush}" Style="{StaticResource ConnectionIndicator}"/>
                            <TextBlock Text="Corsair" FontSize="11" Foreground="{Binding CorsairStatusBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D000000" BorderBrush="{Binding LogitechStatusBrush}" BorderThickness="1" 
                            CornerRadius="10" Padding="10,4" Margin="0,0,8,0"
                            ToolTip="{Binding LogitechStatusDetail}"
                            Visibility="{Binding IsLogitechEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Fill="{Binding LogitechStatusBrush}" Style="{StaticResource ConnectionIndicator}"/>
                            <TextBlock Text="Logitech" FontSize="11" Foreground="{Binding LogitechStatusBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#0D000000" BorderBrush="{Binding RazerStatusBrush}" BorderThickness="1" 
                            CornerRadius="10" Padding="10,4" Margin="0,0,8,0"
                            ToolTip="{Binding RazerStatusDetail}"
                            Visibility="{Binding IsRazerEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Fill="{Binding RazerStatusBrush}" Style="{StaticResource ConnectionIndicator}"/>
                            <TextBlock Text="Razer" FontSize="11" Foreground="{Binding RazerStatusBrush}"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1AE6002E" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1" 
                            CornerRadius="10" Padding="10,4"
                            Visibility="{Binding IsKeyboardLightingAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Fill="{StaticResource AccentBrush}" Style="{StaticResource ConnectionIndicator}"/>
                            <TextBlock Text="OMEN Keyboard" FontSize="11" Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
            
            <!-- Sync All Button -->
            <Button Grid.Column="1" Command="{Binding SyncAllRgbCommand}"
                    VerticalAlignment="Top" Margin="0,0,0,0"
                    ToolTip="Sync current color across all connected RGB devices">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Padding" Value="20,12"/>
                        <Setter Property="Cursor" Value="Hand"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="border" Background="{TemplateBinding Background}" 
                                            CornerRadius="8" Padding="{TemplateBinding Padding}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="🔗" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                            <TextBlock Text="Sync All RGB" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#FF005C"/>
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="border" Property="Background" Value="#CC0025"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>
        </Grid>

        <ScrollViewer Grid.Row="1">
            <StackPanel>
                <!-- Scene Quick Select Section -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding IsSceneServiceEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                            <TextBlock Text="🎨" FontSize="24" Margin="0,0,12,0" VerticalAlignment="Center"/>
                            <TextBlock Text="Scene Quick Select" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#1A9C27B0" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentSceneName, StringFormat='Active: {0}'}" FontSize="10" Foreground="#9C27B0"/>
                            </Border>
                        </StackPanel>
                        
                        <!-- Scene Grid -->
                        <ItemsControl ItemsSource="{Binding Scenes}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Margin="0,0,8,8" Padding="12,8"
                                            Command="{Binding DataContext.ApplySceneCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="{Binding Description}">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Background" Value="{StaticResource SurfaceMediumBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                                <Setter Property="BorderThickness" Value="1"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                <Setter Property="Cursor" Value="Hand"/>
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="border" 
                                                                    Background="{TemplateBinding Background}" 
                                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                                    CornerRadius="6" Padding="{TemplateBinding Padding}">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <TextBlock Text="{Binding Icon}" FontSize="16" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                                                </StackPanel>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsMouseOver" Value="True">
                                                                    <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                                                    <Setter TargetName="border" Property="Background" Value="#1AE6002E"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        
                        <!-- Ambient Mode Toggle -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Ambient Screen Lighting" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="RGB syncs with screen edge colors" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsAmbientModeActive, Mode=TwoWay}"
                                          Style="{StaticResource ToggleButtonStyle}"/>
                        </Grid>

                        <!-- Audio Reactive Toggle -->
                        <Grid Margin="0,12,0,0"
                              Visibility="{Binding IsAudioReactiveModeAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Audio Reactive Lighting" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                <TextBlock Text="Pulses with system audio output via WASAPI loopback" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}"/>
                                <TextBlock Text="{Binding AudioReactiveLevelText}" FontSize="11"
                                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1" IsChecked="{Binding IsAudioReactiveModeActive, Mode=TwoWay}"
                                          Style="{StaticResource ToggleButtonStyle}"/>
                        </Grid>

                        <Grid Margin="0,8,0,0"
                              Visibility="{Binding IsAudioReactiveModeAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="200"/>
                                <ColumnDefinition Width="16"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Mode" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                            <ComboBox Grid.Column="1" ItemsSource="{Binding AudioVisualizationModes}"
                                      SelectedItem="{Binding SelectedAudioVisualizationMode, Mode=TwoWay}"
                                      Style="{StaticResource ModernComboBox}"/>

                            <TextBlock Grid.Column="3" Text="Sensitivity" VerticalAlignment="Center"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0"/>
                            <Slider Grid.Column="4" Minimum="0.1" Maximum="1" TickFrequency="0.05" IsSnapToTickEnabled="True"
                                    Value="{Binding AudioReactiveSensitivity, Mode=TwoWay}"/>
                        </Grid>
                    </StackPanel>
                </Border>
                
                <!-- Corsair Devices Section -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Brand Header with Logo -->
                        <StackPanel Style="{StaticResource BrandSectionHeader}">
                            <Image Source="pack://application:,,,/Assets/corsair.png" Width="28" Height="28" Margin="0,0,12,0"/>
                            <TextBlock Text="Corsair Devices" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#0D000000" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                    BorderBrush="{Binding CorsairStatusBrush}" BorderThickness="1"
                                    ToolTip="{Binding CorsairStatusDetail}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Fill="{Binding CorsairStatusBrush}" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding CorsairStatusDetail}" FontSize="10" Foreground="{Binding CorsairStatusBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <!-- Device Discovery -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding CorsairDeviceStatusText}" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="1" 
                                    Content="Discover Devices" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding DiscoverCorsairDevicesCommand}"
                                    Padding="16,8"/>
                        </Grid>

                        <!-- Corsair Device List -->
                        <ItemsControl ItemsSource="{Binding CorsairDevices}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DeviceCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Device Icon -->
                                            <Border Grid.Column="0" Width="48" Height="48" 
                                                    Background="{StaticResource SurfaceMediumBrush}"
                                                    CornerRadius="24" Margin="0,0,16,0">
                                                <Image Source="pack://application:,,,/Assets/corsair.png" 
                                                       Width="32" Height="32" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Device Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding DeviceType, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Border Background="#1A4CAF50" CornerRadius="6" Padding="6,2" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Status, Mode=OneWay}" FontSize="10" Foreground="#4CAF50"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Identify Button -->
                                            <Button Grid.Column="2" 
                                                    Content="💡 Identify"
                                                    Style="{StaticResource ModernButton}"
                                                    Command="{Binding DataContext.FlashCorsairDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="Flash device LEDs to identify this device"
                                                    Padding="12,6"
                                                    Margin="8,0,0,0"
                                                    VerticalAlignment="Center"/>

                                            <!-- DPI Info (for mice) -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="12,0,0,0"
                                                        Visibility="{Binding IsMouse, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                <TextBlock Text="DPI" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding CurrentDpi}" 
                                                           Style="{StaticResource MonospaceValue}"
                                                           FontSize="16" Foreground="{StaticResource AccentBrush}"
                                                           HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Corsair Lighting Presets -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Lighting Preset:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <ComboBox Grid.Column="1" 
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding CorsairLightingPresets}"
                                      SelectedItem="{Binding SelectedCorsairLightingPreset}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,12,0"/>
                            
                            <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Apply" Style="{StaticResource ModernButton}" Command="{Binding ApplyCorsairLightingCommand}" Padding="16,8" Margin="0,0,8,0"/>
                                <Button Content="Apply to System" Style="{StaticResource ModernButton}" Command="{Binding ApplyCorsairPresetToSystemCommand}" Padding="12,8"/>
                            </StackPanel>
                        </Grid>

                        <!-- Custom RGB Color with Color Picker -->
                        <Expander Header="Custom RGB Color" 
                                  Margin="0,16,0,0"
                                  IsExpanded="False">
                            <StackPanel Margin="0,12,0,0">
                                <controls:ColorPickerControl HexValue="{Binding CorsairColorHex, Mode=TwoWay}" 
                                                             Margin="0,0,0,16"/>
                                
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Grid.Column="0" Text="Color (Hex):" 
                                               FontSize="14" 
                                               Foreground="{StaticResource TextPrimaryBrush}"
                                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                                    
                                    <TextBox Grid.Column="1" 
                                             Style="{StaticResource ModernTextBox}"
                                             Text="{Binding CorsairColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             Margin="0,0,12,0"
                                             MaxLength="7"/>
                                    
                                    <Button Grid.Column="2" 
                                            Content="Apply Color" 
                                            Style="{StaticResource ModernButton}"
                                            Command="{Binding ApplyCorsairCustomColorCommand}"
                                            Padding="16,8"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <!-- DPI Configuration (for mice) -->
                        <Expander Header="DPI Configuration" 
                                  Margin="0,16,0,0"
                                  IsExpanded="False"
                                  Visibility="{Binding HasCorsairMouse, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Margin="0,12,0,0">
                                <TextBlock Text="DPI Stages:" FontSize="14" 
                                           Foreground="{StaticResource TextPrimaryBrush}" 
                                           Margin="0,0,0,8"/>
                                
                                <ItemsControl ItemsSource="{Binding CorsairDpiStages}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,0,0,8">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Grid.Column="0" 
                                                           Text="{Binding Name, StringFormat={}{0}:}" 
                                                           FontSize="12" 
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           VerticalAlignment="Center" 
                                                           Width="60"/>
                                                
                                                <Slider Grid.Column="1" 
                                                        Minimum="400" Maximum="18000" 
                                                        TickFrequency="100" 
                                                        Value="{Binding Dpi}"
                                                        Margin="12,0"/>
                                                
                                                <TextBlock Grid.Column="2" 
                                                           Text="{Binding Dpi, StringFormat={}{0} DPI}" 
                                                           FontSize="12" 
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           VerticalAlignment="Center" 
                                                           Width="80" TextAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Orientation="Horizontal" Grid.Column="0" VerticalAlignment="Center">
                                        <ComboBox Style="{StaticResource ModernComboBox}"
                                                  ItemsSource="{Binding CorsairDpiProfiles}"
                                                  SelectedItem="{Binding SelectedCorsairDpiProfile}"
                                                  DisplayMemberPath="Name"
                                                  Width="220" Margin="0,0,8,0"
                                                  ToolTip="Select a saved DPI profile (Save with same name will prompt to overwrite)"/>

                                        <Button Content="Save Profile" Style="{StaticResource ModernButton}" Command="{Binding SaveCorsairDpiProfileCommand}" Padding="12,6" Margin="0,0,8,0" ToolTip="Save current DPI stages as a profile"/>
                                        <Button Content="Apply Profile" Style="{StaticResource ModernButton}" Command="{Binding ApplyCorsairDpiProfileCommand}" Padding="12,6" Margin="0,0,8,0" ToolTip="Apply selected DPI profile to current stages"/>
                                        <Button Content="Delete" Style="{StaticResource ModernButton}" Command="{Binding DeleteCorsairDpiProfileCommand}" Padding="12,6" ToolTip="Delete the selected DPI profile" />
                                    </StackPanel>

                                    <StackPanel Orientation="Horizontal" Grid.Column="1" HorizontalAlignment="Right">
                                        <Button Content="Restore Defaults" 
                                                Style="{StaticResource ModernButton}"
                                                Command="{Binding RestoreCorsairDpiCommand}"
                                                Padding="12,6" Margin="0,0,8,0"/>
                                        <Button Content="Apply DPI Settings" 
                                                Style="{StaticResource ModernButton}"
                                                Command="{Binding ApplyCorsairDpiCommand}"
                                                Padding="16,8" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </Border>

                <!-- Logitech Devices Section -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Brand Header with Logo -->
                        <StackPanel Style="{StaticResource BrandSectionHeader}">
                            <Image Source="pack://application:,,,/Assets/logitechg.png" Width="28" Height="28" Margin="0,0,12,0"/>
                            <TextBlock Text="Logitech Devices" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#0D000000" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                    BorderBrush="{Binding LogitechStatusBrush}" BorderThickness="1"
                                    ToolTip="{Binding LogitechStatusDetail}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Fill="{Binding LogitechStatusBrush}" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding LogitechStatusDetail}" FontSize="10" Foreground="{Binding LogitechStatusBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <!-- System RGB Section -->
                        <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="🎨 Apply to All System RGB" FontSize="14" FontWeight="SemiBold" 
                                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                                <TextBlock Text="Sync color across all detected Logitech devices" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12"/>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <controls:ColorPickerControl HexValue="{Binding SystemColorHex, Mode=TwoWay}" Width="220"/>
                                    <Button Content="Apply to System" Style="{StaticResource ModernButton}" Command="{Binding ApplyToSystemCommand}" Padding="16,8" Margin="12,0,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        
                        <!-- Device Discovery -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding LogitechDeviceStatusText}" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="1" 
                                    Content="Discover Devices" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding DiscoverLogitechDevicesCommand}"
                                    Padding="16,8"/>
                        </Grid>

                        <!-- Logitech Device List -->
                        <ItemsControl ItemsSource="{Binding LogitechDevices}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DeviceCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Device Icon -->
                                            <Border Grid.Column="0" Width="48" Height="48" 
                                                    Background="{StaticResource SurfaceMediumBrush}"
                                                    CornerRadius="24" Margin="0,0,16,0">
                                                <Image Source="pack://application:,,,/Assets/logitechg.png" 
                                                       Width="32" Height="32" 
                                                       HorizontalAlignment="Center" 
                                                       VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Device Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding DeviceType, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Border Background="#1A45C7FF" CornerRadius="6" Padding="6,2" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Status, Mode=OneWay}" FontSize="10" Foreground="#45C7FF"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Color Preview -->
                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Border Width="36" Height="36" 
                                                        Background="{Binding CurrentColor}" 
                                                        BorderBrush="{StaticResource BorderBrush}" 
                                                        BorderThickness="2" 
                                                        CornerRadius="8"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Logitech Static Color -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Static Color:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Red" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LogitechRedValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Green" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LogitechGreenValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                <TextBlock Text="Blue" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding LogitechBlueValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <Button Grid.Column="5" 
                                    Content="Apply Color" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyLogitechColorCommand}"
                                    Padding="16,8" 
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Razer Devices Section -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <!-- Brand Header with Logo -->
                        <StackPanel Style="{StaticResource BrandSectionHeader}">
                            <Border Width="28" Height="28" Background="#44D62C" CornerRadius="6" Margin="0,0,12,0">
                                <TextBlock Text="R" FontSize="16" FontWeight="Bold" Foreground="Black"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Razer Devices" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#0D000000" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center"
                                    BorderBrush="{Binding RazerStatusBrush}" BorderThickness="1"
                                    ToolTip="{Binding RazerStatusDetail}">
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Fill="{Binding RazerStatusBrush}" Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBlock Text="{Binding RazerStatusDetail}" FontSize="10" Foreground="{Binding RazerStatusBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="Requires Razer Synapse to be installed and running" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- Device Discovery -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" 
                                       Text="{Binding RazerDeviceStatusText}" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"/>
                            
                            <Button Grid.Column="1" 
                                    Content="Discover Devices" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding DiscoverRazerDevicesCommand}"
                                    Padding="16,8"/>
                        </Grid>

                        <!-- Razer Device List -->
                        <ItemsControl ItemsSource="{Binding RazerDevices}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DeviceCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Razer Icon -->
                                            <Border Grid.Column="0" Width="48" Height="48" 
                                                    Background="#44D62C" CornerRadius="24" Margin="0,0,16,0">
                                                <TextBlock Text="R" FontSize="22" FontWeight="Bold"
                                                           Foreground="Black"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Device Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding DeviceType, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <Border Background="#1A44D62C" CornerRadius="6" Padding="6,2" Margin="8,0,0,0">
                                                        <TextBlock Text="{Binding Status, Mode=OneWay}" FontSize="10" Foreground="#44D62C"/>
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Razer Static Color -->
                        <TextBlock Text="Lighting Control" FontSize="16" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,12"/>
                        
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Color:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <StackPanel Grid.Column="1" Margin="0,0,8,0">
                                <TextBlock Text="Red" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RazerRedValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="2" Margin="0,0,8,0">
                                <TextBlock Text="Green" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RazerGreenValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <StackPanel Grid.Column="3" Margin="0,0,8,0">
                                <TextBlock Text="Blue" FontSize="12" 
                                           Foreground="{StaticResource TextSecondaryBrush}" 
                                           Margin="0,0,0,4"/>
                                <TextBox Text="{Binding RazerBlueValue, UpdateSourceTrigger=PropertyChanged}" 
                                         FontSize="14"/>
                            </StackPanel>
                            
                            <Button Grid.Column="5" 
                                    Content="Apply Static" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyRazerColorCommand}"
                                    Padding="16,8" 
                                    VerticalAlignment="Bottom"/>
                        </Grid>
                        
                        <!-- Razer Effects -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            
                            <Button Grid.Column="0" 
                                    Content="Breathing" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyRazerBreathingCommand}"
                                    Padding="16,8" 
                                    Margin="0,0,8,0"/>
                            
                            <Button Grid.Column="1" 
                                    Content="Spectrum Cycle" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyRazerSpectrumCommand}"
                                    Padding="16,8"/>
                        </Grid>
                        
                        <!-- Note about limited Razer support -->
                        <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="4" 
                                Padding="12" Margin="0,16,0,0">
                            <TextBlock Text="Razer support is limited to detected-device status and validated lighting actions for supported hardware." 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- OpenRGB Devices Section (Desktop RGB Support) -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding HasOpenRgbDevices, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <!-- Brand Header with Logo -->
                        <StackPanel Style="{StaticResource BrandSectionHeader}">
                            <Border Width="28" Height="28" Background="#FF6B35" CornerRadius="6" Margin="0,0,12,0">
                                <TextBlock Text="🌈" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="OpenRGB Devices" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#1AFF6B35" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding OpenRgbStatusText}" FontSize="10" Foreground="#FF6B35"/>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="Generic RGB control via OpenRGB server (motherboard, RAM, GPU, fans, strips, etc.)" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,16"/>
                        
                        <!-- OpenRGB Device List -->
                        <ItemsControl ItemsSource="{Binding OpenRgbDevices}" Margin="0,0,0,16">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource DeviceCard}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Device Icon -->
                                            <Border Grid.Column="0" Width="48" Height="48" 
                                                    Background="#FF6B35" CornerRadius="24" Margin="0,0,16,0">
                                                <TextBlock Text="💡" FontSize="18"
                                                           HorizontalAlignment="Center" 
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <!-- Device Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontSize="14" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                    <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                        <Run Text="{Binding Type, Mode=OneWay}"/>
                                                        <Run Text=" • "/>
                                                        <Run Text="{Binding Vendor, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                            
                                            <!-- LED Count -->
                                            <Border Grid.Column="2" Background="#1AFF6B35" CornerRadius="6" Padding="8,4" VerticalAlignment="Center">
                                                <TextBlock FontSize="11" Foreground="#FF6B35">
                                                    <Run Text="{Binding LedCount, Mode=OneWay}"/>
                                                    <Run Text=" LEDs"/>
                                                </TextBlock>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Quick Color Buttons for OpenRGB -->
                        <TextBlock Text="⚡ QUICK COLORS" 
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" 
                                   Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,0">
                            <Button Content="🔴" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Red"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#FF0000"/>
                            <Button Content="🔵" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Blue"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#0066FF"/>
                            <Button Content="🟢" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Green"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#00FF00"/>
                            <Button Content="🟣" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Purple"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#9400D3"/>
                            <Button Content="🟡" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Yellow"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#FFFF00"/>
                            <Button Content="⚪" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="White"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#FFFFFF"/>
                            <Button Content="🟠" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Orange"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#FF6B35"/>
                            <Button Content="⬛" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Off"
                                    Command="{Binding ApplyOpenRgbColorCommand}" CommandParameter="#000000"/>
                        </WrapPanel>
                        
                        <!-- Info Box -->
                        <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="4" 
                                Padding="12" Margin="0,16,0,0">
                            <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="OpenRGB Integration:"/>
                                <Run Text=" Controls any RGB device supported by OpenRGB (motherboards, RAM, GPUs, coolers, LED strips, etc). "/>
                                <Run Text="Download OpenRGB from openrgb.org and enable the SDK Server (Settings → SDK Server → Start Server)."/>
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- HP OMEN Keyboard Lighting -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding IsKeyboardLightingAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <StackPanel>
                        <!-- Brand Header with Icon -->
                        <StackPanel Style="{StaticResource BrandSectionHeader}">
                            <Border Width="28" Height="28" Background="{StaticResource AccentBrush}" CornerRadius="6" Margin="0,0,12,0">
                                <TextBlock Text="⌨️" FontSize="14"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="HP OMEN Keyboard" FontSize="20" FontWeight="SemiBold" 
                                       Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            <Border Background="#1AE6002E" CornerRadius="8" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding KeyboardLightingBackend}" FontSize="10" Foreground="{StaticResource AccentBrush}"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        
                        <TextBlock Text="Your laptop's built-in 4-zone RGB keyboard" 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,12"/>
                        
                        <!-- Quick Color Buttons -->
                        <TextBlock Text="⚡ QUICK COLORS (click to apply to all zones)" 
                                   FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextTertiaryBrush}" 
                                   Margin="0,0,0,8"/>
                        <WrapPanel Margin="0,0,0,16">
                            <Button Content="🔴" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="OMEN Red"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#E6002E"/>
                            <Button Content="🔵" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Blue"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#0066FF"/>
                            <Button Content="🟢" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Green"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#00FF00"/>
                            <Button Content="🟣" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Purple"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#9400D3"/>
                            <Button Content="🟡" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Yellow"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#FFFF00"/>
                            <Button Content="⚪" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="White"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#FFFFFF"/>
                            <Button Content="🩵" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Cyan"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#00FFFF"/>
                            <Button Content="🩷" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Pink"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#FF69B4"/>
                            <Button Content="⬛" FontSize="14" Padding="8,4" Margin="0,0,6,4"
                                    Style="{StaticResource ModernButton}" ToolTip="Off"
                                    Command="{Binding ApplyQuickColorCommand}" CommandParameter="#000000"/>
                        </WrapPanel>
                        
                        <!-- Keyboard Status Hint (shows tips for models where WMI may not work) -->
                        <Border Background="#1A8B5CF6" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                                Visibility="{Binding KeyboardLightingHint, Converter={StaticResource StringNotEmptyToVisibilityConverter}}">
                            <TextBlock Text="{Binding KeyboardLightingHint}" 
                                       FontSize="12" 
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"/>
                        </Border>

                        <!-- Keyboard Zone Display - Visual Schematic -->
                        <TextBlock Text="🎹 KEYBOARD ZONES (click zone to change color)" 
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   Margin="0,8,0,12"/>

                        <!-- Visual laptop keyboard schematic -->
                        <Border Background="#0D0D0D" CornerRadius="10" Padding="14,10" Margin="0,0,0,16"
                                BorderBrush="#333" BorderThickness="2">
                            <!-- Function row spacer -->
                            <StackPanel>
                                <!-- Function key row (decorative) -->
                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding Zone1Brush}" Opacity="0.25" CornerRadius="3" Height="10" Margin="0,0,2,0"/>
                                    <Border Grid.Column="1" Background="{Binding Zone2Brush}" Opacity="0.25" CornerRadius="3" Height="10" Margin="2,0"/>
                                    <Border Grid.Column="2" Background="{Binding Zone3Brush}" Opacity="0.25" CornerRadius="3" Height="10" Margin="2,0"/>
                                    <Border Grid.Column="3" Background="{Binding Zone4Brush}" Opacity="0.25" CornerRadius="3" Height="10" Margin="2,0,0,0"/>
                                </Grid>
                                <!-- Main key area (clickable zones) -->
                                <Grid Height="110">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Zone 1 -->
                                    <Border Grid.Column="0" CornerRadius="6" Margin="0,0,2,0" Cursor="Hand"
                                            BorderBrush="{Binding Zone1Brush}" BorderThickness="1.5">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SetZone1ColorCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Rectangle Fill="{Binding Zone1Brush}" Opacity="0.18" RadiusX="5" RadiusY="5"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                            <TextBlock Text="ESC  F1-F4" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="~ 1 2 3 4 5" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="TAB Q W E R T" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="CAPS A S D F G" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="SHIFT Z X C V" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Zone 1" FontSize="10" FontWeight="Bold" Foreground="{Binding Zone1Brush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Zone 2 -->
                                    <Border Grid.Column="1" CornerRadius="6" Margin="2,0" Cursor="Hand"
                                            BorderBrush="{Binding Zone2Brush}" BorderThickness="1.5">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SetZone2ColorCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Rectangle Fill="{Binding Zone2Brush}" Opacity="0.18" RadiusX="5" RadiusY="5"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                            <TextBlock Text="F5-F8" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="6 7 8" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Y U I" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="H J K" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="B N M" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Zone 2" FontSize="10" FontWeight="Bold" Foreground="{Binding Zone2Brush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Zone 3 -->
                                    <Border Grid.Column="2" CornerRadius="6" Margin="2,0" Cursor="Hand"
                                            BorderBrush="{Binding Zone3Brush}" BorderThickness="1.5">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SetZone3ColorCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Rectangle Fill="{Binding Zone3Brush}" Opacity="0.18" RadiusX="5" RadiusY="5"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                            <TextBlock Text="F9-F12" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="9 0 - =" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="O P [ ]" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="L ; ' \" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text=", . / SHIFT" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Zone 3" FontSize="10" FontWeight="Bold" Foreground="{Binding Zone3Brush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <!-- Zone 4 -->
                                    <Border Grid.Column="3" CornerRadius="6" Margin="2,0,0,0" Cursor="Hand"
                                            BorderBrush="{Binding Zone4Brush}" BorderThickness="1.5">
                                        <Border.InputBindings>
                                            <MouseBinding MouseAction="LeftClick" Command="{Binding SetZone4ColorCommand}"/>
                                        </Border.InputBindings>
                                        <Grid>
                                            <Rectangle Fill="{Binding Zone4Brush}" Opacity="0.18" RadiusX="5" RadiusY="5"/>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,8">
                                            <TextBlock Text="Del Ins" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="BS  \  ]" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="ENTER" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="▲" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="◄ ▼ ►" FontSize="9" FontWeight="SemiBold" Foreground="White" Opacity="0.55" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Zone 4" FontSize="10" FontWeight="Bold" Foreground="{Binding Zone4Brush}" HorizontalAlignment="Center" Margin="0,6,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                                <!-- Space bar row (decorative) -->
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="0.5*"/>
                                        <ColumnDefinition Width="5*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0" Background="{Binding Zone1Brush}" Opacity="0.2" CornerRadius="2" Height="10" Margin="0,0,2,0"/>
                                    <Border Grid.Column="1" Background="#333" CornerRadius="4" Height="10" Margin="2,0"/>
                                    <Border Grid.Column="2" Background="{Binding Zone4Brush}" Opacity="0.2" CornerRadius="2" Height="10" Margin="2,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Hex color inputs for each zone -->
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="2.5*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,2,0" HorizontalAlignment="Center">
                                <Ellipse Width="14" Height="14" Fill="{Binding Zone1Brush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Zone1ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="10" Width="70" TextAlignment="Center" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="2,0" HorizontalAlignment="Center">
                                <Ellipse Width="14" Height="14" Fill="{Binding Zone2Brush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Zone2ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="10" Width="70" TextAlignment="Center" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="2,0" HorizontalAlignment="Center">
                                <Ellipse Width="14" Height="14" Fill="{Binding Zone3Brush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Zone3ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="10" Width="70" TextAlignment="Center" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="3" Margin="2,0,0,0" HorizontalAlignment="Center">
                                <Ellipse Width="14" Height="14" Fill="{Binding Zone4Brush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
                                <TextBox Text="{Binding Zone4ColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         FontSize="10" Width="70" TextAlignment="Center" Style="{StaticResource ModernTextBox}"/>
                            </StackPanel>
                        </Grid>
                        
                        <!-- Preset Selection and Apply Buttons -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Grid.Column="0" Text="Preset:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <ComboBox Grid.Column="1" 
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding KeyboardPresets}"
                                      SelectedItem="{Binding SelectedKeyboardPreset}"
                                      DisplayMemberPath="Name"
                                      Margin="0,0,12,0"/>
                            
                            <Button Grid.Column="2" 
                                    Content="Apply to Keyboard" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyKeyboardColorsCommand}"
                                    Padding="16,8"
                                    Margin="0,0,8,0"/>
                            
                            <Button Grid.Column="3" 
                                    Content="All Same Color" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding ApplyAllZonesSameColorCommand}"
                                    Padding="16,8"
                                    ToolTip="Apply Zone 1 color to all zones"/>
                        </Grid>
                        
                        <!-- Apply on Startup Toggle -->
                        <Border Background="{StaticResource SurfaceDarkBrush}" 
                                CornerRadius="8" Padding="16" Margin="0,12,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Apply Colors on Startup" 
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Automatically restore saved keyboard colors when OmenCore starts" 
                                               FontSize="11" 
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                                
                                <ToggleButton Grid.Column="1" 
                                              IsChecked="{Binding ApplyKeyboardColorsOnStartup, Mode=TwoWay}"
                                              Style="{StaticResource ModernToggleButton}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Per-Key Lighting Section -->
                        <Border Background="{StaticResource SurfaceDarkBrush}" CornerRadius="8"
                                Margin="0,12,0,0" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Per-Key RGB" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <Border Background="#1A8B5CF6" CornerRadius="6" Padding="8,3" Margin="12,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="OMEN Max" FontSize="10" Foreground="#8B5CF6"/>
                                    </Border>
                                </StackPanel>

                                <!-- Explanation card when per-key not available -->
                                <Border Background="#12FFFFFF" CornerRadius="6" Padding="12"
                                        Visibility="{Binding IsPerKeyLightingAvailable, Converter={StaticResource InverseBoolToVisibility}}">
                                    <TextBlock Text="{Binding PerKeyCapabilitySummary}"
                                               FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                               TextWrapping="Wrap"/>
                                </Border>

                                <!-- Per-key editor when supported -->
                                <StackPanel Visibility="{Binding IsPerKeyLightingAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <!-- Brush color row -->
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Brush:" FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Border Grid.Column="1" Width="26" Height="26" CornerRadius="4"
                                                Background="{Binding SelectedPerKeyColorBrush}"
                                                BorderBrush="#444" BorderThickness="1" Margin="0,0,8,0"/>
                                        <TextBox Grid.Column="2" Style="{StaticResource ModernTextBox}"
                                                 Text="{Binding SelectedPerKeyColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 MaxLength="7" Width="72" Margin="0,0,12,0"/>
                                        <Button Grid.Column="4" Content="Fill All" Style="{StaticResource ModernButton}"
                                                Command="{Binding FillAllPerKeyCommand}" Padding="12,6" Margin="0,0,8,0"/>
                                        <Button Grid.Column="5" Content="Apply to Keyboard"
                                                Style="{StaticResource ModernButton}"
                                                Command="{Binding ApplyPerKeyLightingCommand}" Padding="16,6"/>
                                    </Grid>
                                    <!-- Key grid -->
                                    <Border Background="#0D0D0D" CornerRadius="8" Padding="8"
                                            BorderBrush="#333" BorderThickness="1.5">
                                        <ItemsControl ItemsSource="{Binding PerKeyGrid}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <UniformGrid Rows="6" Columns="14"/>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="1" CornerRadius="3" Height="28"
                                                            Background="{Binding KeyBrush}"
                                                            BorderBrush="#444" BorderThickness="1"
                                                            ToolTip="{Binding KeyName}">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Cursor" Value="Hand"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsVisible}" Value="False">
                                                                        <Setter Property="Background" Value="Transparent"/>
                                                                        <Setter Property="BorderBrush" Value="Transparent"/>
                                                                        <Setter Property="IsHitTestVisible" Value="False"/>
                                                                        <Setter Property="Cursor" Value="Arrow"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Border.InputBindings>
                                                            <MouseBinding MouseAction="LeftClick"
                                                                          Command="{Binding DataContext.PaintKeyCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                          CommandParameter="{Binding}"/>
                                                        </Border.InputBindings>
                                                        <TextBlock Text="{Binding KeyLabel}" FontSize="7"
                                                                   Foreground="White" Opacity="0.7"
                                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                                   TextWrapping="NoWrap"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Advanced Lighting Effects -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="🎨 Advanced Lighting Effects" FontSize="20" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>

                        <!-- Temperature-Responsive Lighting -->
                        <Border Background="{StaticResource SurfaceDarkBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🌡️ Temperature-Responsive Lighting"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Keyboard and RGB devices change color based on CPU/GPU temperature"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding TemperatureResponsiveLightingEnabled, Mode=TwoWay}"
                                              Style="{StaticResource ModernToggleButton}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Temperature Thresholds -->
                        <Border Background="{StaticResource SurfaceMediumBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                Visibility="{Binding TemperatureResponsiveLightingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Temperature Thresholds (°C)" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                        <TextBlock Text="Low" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBox Text="{Binding CpuTempThresholdLow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="4,0">
                                        <TextBlock Text="Medium" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBox Text="{Binding CpuTempThresholdMedium, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" Margin="8,0,0,0">
                                        <TextBlock Text="High" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                                        <TextBox Text="{Binding CpuTempThresholdHigh, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Grid>

                                <!-- Color Pickers for Temperature Levels -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{Binding TempLowColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="0,0,8,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Low Temp" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding TempLowColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Background="{Binding TempMediumColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="4,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Medium Temp" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding TempMediumColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="{Binding TempHighColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="8,0,0,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="High Temp" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding TempHighColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Performance Mode Synced Lighting -->
                        <Border Background="{StaticResource SurfaceDarkBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="⚡ Performance Mode Synced Lighting"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="RGB devices change color based on current performance mode"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding PerformanceModeSyncedLightingEnabled, Mode=TwoWay}"
                                              Style="{StaticResource ModernToggleButton}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Performance Mode Colors -->
                        <Border Background="{StaticResource SurfaceMediumBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12"
                                Visibility="{Binding PerformanceModeSyncedLightingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Performance Mode Colors" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Background="{Binding BalancedModeColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="0,0,8,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Balanced" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding BalancedModeColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="1" Background="{Binding PerformanceModeColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="4,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Performance" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding PerformanceModeColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="2" Background="{Binding QuietModeColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="4,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Quiet" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding QuietModeColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>

                                    <Border Grid.Column="3" Background="{Binding CustomModeColorHex, Converter={StaticResource HexToBrushConverter}}"
                                            CornerRadius="6" Padding="8" Margin="8,0,0,0" Cursor="Hand">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Custom" FontSize="10" Foreground="White" FontWeight="SemiBold"/>
                                            <TextBox Text="{Binding CustomModeColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Style="{StaticResource ModernTextBox}" FontSize="10" Margin="0,4,0,0" Width="70"/>
                                        </StackPanel>
                                    </Border>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Throttling Indicators -->
                        <Border Background="{StaticResource SurfaceDarkBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="🚨 Throttling Indicators"
                                               FontSize="14" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                    <TextBlock Text="Flash red/orange when CPU/GPU thermal or power throttling occurs"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               Margin="0,2,0,0"/>
                                </StackPanel>

                                <ToggleButton Grid.Column="1"
                                              IsChecked="{Binding ThrottlingIndicatorLightingEnabled, Mode=TwoWay}"
                                              Style="{StaticResource ModernToggleButton}"
                                              VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Throttling Color -->
                        <Border Background="{StaticResource SurfaceMediumBrush}"
                                CornerRadius="8" Padding="16" Margin="0,0,0,0"
                                Visibility="{Binding ThrottlingIndicatorLightingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <TextBlock Text="Throttling Warning Color" FontSize="12" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,8"/>

                                <Border Background="{Binding ThrottlingColorHex, Converter={StaticResource HexToBrushConverter}}"
                                        CornerRadius="6" Padding="12" Cursor="Hand">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                        <TextBlock Text="⚠️ Throttling Alert" FontSize="12" Foreground="White" FontWeight="SemiBold"/>
                                        <TextBox Text="{Binding ThrottlingColorHex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                 Style="{StaticResource ModernTextBox}" FontSize="10" Margin="12,0,0,0" Width="70"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Keyboard Unavailable Message -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24" Margin="0,0,0,16"
                        Visibility="{Binding IsKeyboardLightingAvailable, Converter={StaticResource InverseBoolToVisibility}}">
                    <StackPanel>
                        <TextBlock Text="HP OMEN Keyboard" FontSize="20" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,8"/>
                        <TextBlock Text="Keyboard lighting control is not available on this system." 
                                   FontSize="14" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="This feature requires a supported HP OMEN laptop with 4-zone RGB keyboard and the WMI BIOS interface." 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Macro Profiles (Corsair) -->
                <Border Style="{StaticResource SurfaceCard}" Padding="24">
                    <StackPanel>
                        <TextBlock Text="Macro Profiles" FontSize="20" FontWeight="SemiBold" 
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
                        
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Active Profile:" 
                                       FontSize="14" 
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center" Margin="0,0,12,0"/>
                            
                            <ComboBox Grid.Column="1" 
                                      Style="{StaticResource ModernComboBox}"
                                      ItemsSource="{Binding MacroProfiles}"
                                      SelectedItem="{Binding SelectedMacroProfile}"
                                      DisplayMemberPath="ProfileName"
                                      Margin="0,0,12,0"/>
                            
                            <Button Grid.Column="2" 
                                    Content="Load Profile" 
                                    Style="{StaticResource ModernButton}"
                                    Command="{Binding LoadMacroProfileCommand}"
                                    Padding="16,8"/>
                        </Grid>

                        <TextBlock Text="Use Corsair iCUE or Logitech G HUB software for advanced macro configuration." 
                                   FontSize="12" 
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,16,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Loading Overlay -->
        <controls:LoadingOverlay Grid.RowSpan="2" Panel.ZIndex="1000" />
    </Grid>
</UserControl>
